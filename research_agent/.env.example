# Copy to .env and fill in.  (cp .env.example .env)

# Which model to use. Format: provider:model
#   openai:gpt-4.1-nano
#   anthropic:claude-sonnet-4-6
#   google_genai:gemini-3.1-flash-lite   (also: pip install langchain-google-genai)
LLM_MODEL=openai:gpt-4.1-nano

# Your key for the provider named in LLM_MODEL above.
LLM_API_KEY=

# Tavily web-search key — free tier at https://tavily.com
TAVILY_API_KEY=
